{
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/(config|database)/.*",
      "status": 403,
      "dest": "/"
    },
    {
      "src": "/.*\\.(sql|env|log|sh|md|yml|yaml)$",
      "status": 403,
      "dest": "/"
    },
    {
      "src": "/(assets/.*)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
